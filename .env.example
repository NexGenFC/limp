# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Django / API
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=replace-with-long-random-string-min-50-chars
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (optional — defaults to SQLite if unset)
# Local CockroachDB (matches docker-compose service `cockroach`):
# DATABASE_URL=postgresql://root@localhost:26257/defaultdb?sslmode=disable

# Redis / Celery (optional in dev — LocMem cache + eager Celery by default)
# REDIS_URL=redis://127.0.0.1:6379/0
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# CELERY_TASK_ALWAYS_EAGER=1

# Kafka (optional — if unset, audit rows are not published to Kafka)
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_AUDIT_TOPIC=limp.audit

# Cassandra (consumer / ops only — Django does not connect directly)
# CASSANDRA_HOSTS=localhost
# CASSANDRA_KEYSPACE=limp

# CORS / CSRF (comma-separated origins, no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# JWT — access token refreshes silently; short-lived by design
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=10
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Keycloak OIDC (optional — disabled if KEYCLOAK_SERVER_URL is empty)
# When enabled, the API accepts Keycloak-issued JWTs alongside SimpleJWT.
# KEYCLOAK_SERVER_URL=http://localhost:8180
# KEYCLOAK_REALM=limp
# KEYCLOAK_CLIENT_ID=limp-api

# Production TLS / HSTS (set in production settings; ignored in dev)
# SECURE_SSL_REDIRECT=1
# SECURE_HSTS_SECONDS=31536000
